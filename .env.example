# Ziqpu — environment template. Copy to `.env` (gitignored) and fill locally.
# NEVER commit real values. The public repo and CI run on fixtures, not on these.
# Every var below is optional: with none set, the loop runs fully deterministic and offline.

# --- Ungasaga (interpreter): live LLM, chosen by precedence ---
# Precedence in agents::build_interpreter():
#   1. OpenAI-compatible / OpenRouter (OPENROUTER_API_KEY or OPENAI_API_KEY)
#   2. Anthropic (ANTHROPIC_API_KEY)
#   3. deterministic template (no key set)
# All are SERVER-SIDE ONLY. Never bundle a key into a client / WASM build.

# Anthropic Messages API (Claude). Model via ZIQPU_MODEL (default: claude-opus-4-8).
ANTHROPIC_API_KEY=

# OpenAI-compatible / OpenRouter. Either key opts into the OpenAI-compat interpreter.
OPENROUTER_API_KEY=
# Optional: a plain OpenAI (or other OpenAI-compatible) key instead of OpenRouter.
OPENAI_API_KEY=
# Optional: override the base URL (default: https://openrouter.ai/api/v1).
OPENAI_BASE_URL=

# Model id for whichever live interpreter is selected. Per-provider defaults when unset:
#   Anthropic  -> claude-opus-4-8
#   OpenRouter -> anthropic/claude-3.5-sonnet
ZIQPU_MODEL=

# --- Grounded source (the checkpoint's costed pull) ---
# Unset (default) -> deterministic mock, no network. Set to any value -> live SEC EDGAR pull.
ZIQPU_LIVE=

# --- Hamun-ana (measurer): optional local model that only *sequences* the tools ---
# Unset (default) -> deterministic sequence. Set to any value -> use a local model.
ZIQPU_LOCAL_LLM=
# openai (default; LM Studio / Jan / llama.cpp-server) | ollama
ZIQPU_LLM_PROVIDER=
# Base URL (default: http://localhost:1234/v1 for openai, http://localhost:11434 for ollama).
ZIQPU_LLM_URL=
# Model id (default: gemma-4-e4b-it for openai, qwen2.5:3b-instruct for ollama).
ZIQPU_LLM_MODEL=

# --- scripts/run-agent.sh | run-agent.ps1 convenience wrappers ---
# The wrappers read these and export the ZIQPU_LLM_* vars above for you.
LOCAL_LLM_BASE_URL=http://localhost:1234/v1
LOCAL_LLM_MODEL=gemma-4-e4b-it

# --- Private Nisaba Postgres (real IPO/natal data), read by the sidecar ---
# Public CI does NOT use this; it runs on fixtures. Local/deploy only.
DATABASE_URL=

# --- Ephemeris data directory (DE440 .bsp etc., fetched via scripts/fetch-ephemeris.sh) ---
EPHEMERIS_PATH=./data/ephemeris

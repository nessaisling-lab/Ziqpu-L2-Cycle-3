# Ziqpu — environment template. Copy to `.env` (gitignored) and fill locally.
# NEVER commit real values. The public repo and CI run on fixtures, not on these.

# --- Ungasaga (interpreter): Claude via the Anthropic API ---
# SERVER-SIDE ONLY. Never bundle this into a client / WASM build.
ANTHROPIC_API_KEY=
UNGASAGA_MODEL=claude-sonnet-5

# --- Hamun-ana (measurer): local Qwen via an OpenAI-compatible endpoint (Ollama/mistral.rs) ---
HAMUN_ANA_MODEL=qwen2.5:3b-instruct
LOCAL_LLM_URL=http://localhost:11434/v1

# --- Read-only sidecar ---
SIDECAR_URL=http://localhost:8787

# --- Private Nisaba Postgres (real IPO/natal data) ---
# Public CI does NOT use this; it runs on fixtures. Local/deploy only.
DATABASE_URL=

# --- Ephemeris data directory (DE440 .bsp etc., fetched via scripts/, not committed) ---
EPHEMERIS_PATH=./data/ephemeris

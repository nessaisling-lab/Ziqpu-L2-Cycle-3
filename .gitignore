# Rust build artifacts
/target/
**/target/
**/*.rs.bk

# Secrets — NEVER commit. Only .env.example is tracked.
.env
.env.*
!.env.example

# Ephemeris data files (large; fetched at build/deploy, licensing tracked separately)
*.bsp
*.se1
/data/ephemeris/

# Archives / stray extraction artifacts — never vendor zips into the tree
*.zip

# Raw data export from the private Nisaba DB — we commit the GENERATED seed, not this
/company_metadata.csv

# Audio assets are kept out of the code repo
*.mp3
*.wav
*.ogg

# OS / editor junk
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/*
!.vscode/extensions.json

# Cloudflare Worker key proxy — local dev secrets + tooling (real secrets go via `wrangler secret put`)
proxy/.dev.vars
**/node_modules/
.wrangler/

# route-3 enrichment working dir (temp)
/route3/

# docx build tooling (temp)
/.docbuild/
